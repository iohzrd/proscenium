{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proscenium",
  "version": "0.1.40",
  "identifier": "com.proscenium.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Proscenium",
        "width": 800,
        "height": 600,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["proscenium"]
      },
      "mobile": [
        {
          "scheme": ["proscenium"]
        }
      ]
    }
  }
}
